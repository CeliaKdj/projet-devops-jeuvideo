{
  "env": {
    "browser": true,
    "es2021": true,
    "mocha": true
  },
  "extends": [
    "eslint:recommended",
    "google"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "camelcase": "off",
    "new-cap": "off",
    "max-len": "off",
    "no-var": "off",
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "prefer-const": "error",
    "require-jsdoc": "off",
    "valid-jsdoc": "off",
    // "max-len": ["warn", { "code": 100 }],
    "object-curly-spacing": ["error", "always"]
  }
}